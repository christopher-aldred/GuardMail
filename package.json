{
  "name": "guardmail",
  "version": "1.0.0",
  "description": "Secure email service with LLM Guard protection, ClamAV scanning, and MCP server",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "echo 'Use individual package dev scripts'",
    "build": "pnpm -r run build",
    "test": "pnpm -r test",
    "lint": "pnpm -r run lint",
    "db:migrate": "pnpm --filter @guardmail/api db:migrate",
    "db:seed": "pnpm --filter @guardmail/api db:seed"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@rollup/rollup-darwin-arm64": "^4.62.2"
  }
}