# Guardmail Environment Variables

# Database
DATABASE_URL=postgresql://postgres:guardmail_dev@localhost:5432/guardmail

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# LLM Guard Service
LLM_GUARD_URL=http://localhost:8000

# ClamAV
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Email Domain
EMAIL_DOMAIN=mydomain.com

# SMTP Server
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_MAX_MESSAGE_MB=35

# Resend API (for fetching full inbound email bodies)
# The inbound webhook payload only includes metadata; the full email
# (text/html/headers) is fetched via GET https://api.resend.com/emails/{id}.
# Falls back to SMTP_PASS if not set.
RESEND_API_KEY=re_your_resend_api_key

# Stripe billing (subscription checkout for Hobby & Pro tiers)
# Get the secret key from Stripe dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Signing secret from Stripe dashboard → Developers → Webhooks (your
# endpoint for /api/webhooks/stripe). Use `stripe listen` locally.
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret
# Stripe Product IDs (Products created in the dashboard with recurring
# GBP prices). The default price of each product is resolved at runtime.
STRIPE_HOBBY_PRODUCT_ID=prod_UmOsoaWpoapUk8
STRIPE_PRO_PRODUCT_ID=prod_UmOuQo5iEZjkzy

# Custom domain verification (hobby + pro + custom tiers)
# The settings API registers a user's custom domain with Resend and polls
# the /domains endpoint for DNS-verification status. The same key used
# for outbound delivery (SMTP_PASS) is reused, falling back to
# RESEND_API_KEY above. When neither is set, POST /api/settings/domain
# returns 503 (feature disabled). No separate env var is required.

# Internal API key (shared between smtp-server and api)
INTERNAL_API_KEY=your-internal-api-key

# API Server
API_PORT=3000
NODE_ENV=development

# MCP Server
MCP_PORT=3001
MCP_API_KEY=your-mcp-api-key

# Web UI
VITE_API_URL=http://localhost:3000
WEB_PORT=5173
WEB_URL=https://aiguard.email

# Rate Limiting (10 requests/second per client IP)
RATE_LIMIT_RPS=10

# Admin Account
# Promote an existing user to admin on startup (ensureSchema) by setting
# ADMIN_EMAIL to their registration email. To seed a brand-new admin via
# `pnpm --filter @guardmail/api db:seed`, also set ADMIN_USERNAME +
# ADMIN_PASSWORD. The username must NOT be a reserved local part.
ADMIN_EMAIL=chris@aldred.dev
# ADMIN_USERNAME=guardmail-admin
# ADMIN_PASSWORD=change-me

# Send Limits
# Unverified Free accounts: lifetime cap before email verification.
UNVERIFIED_SEND_LIMIT=100
# NOTE: per-account send limits are now driven by the subscription
# tier (see TIERS in packages/shared/src/index.ts). The legacy
# VERIFIED_DAILY_SEND_LIMIT env var is no longer used.

# Admin Forwarding
# Destination admin email that receives forwarded copies of inbound mail
# sent from the support addresses below. Leave empty to disable forwarding.
ADMIN_FORWARD_EMAIL=chris@aldred.dev
# Comma-separated sender addresses whose inbound emails are forwarded to
# ADMIN_FORWARD_EMAIL. These are the mailbox addresses mail arrives *for*
# (recipients), not the senders.
FORWARD_FROM_ADDRESSES=help@aiguard.email,contact@aiguard.email,info@aiguard.info,support@aiguard.email
# Reserved service local-parts that cannot be registered as usernames.
# Derived addresses (help@, contact@, info@, support@, admin@, …) are
# forwarded to ADMIN_FORWARD_EMAIL instead of being assigned to users.
# RESERVED_LOCAL_PARTS is not env-configurable; see
# packages/api/src/services/reserved-addresses.ts.

# File Upload
MAX_ATTACHMENT_SIZE_MB=25
