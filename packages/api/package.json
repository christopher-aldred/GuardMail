    "stripe": "^22.3.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.21.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
